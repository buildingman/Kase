{
  "name": "kase",
  "version": "0.1.0",
  "description": "智能 iOS BDD 自动化：BDD(.case) → AI 编译 → Maestro YAML → 模拟器执行",
  "type": "module",
  "bin": {
    "kase": "./dist/cli.js"
  },
  "files": [
    "dist",
    "prompts",
    ".env.example",
    "setup.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "kase": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.1",
    "picocolors": "^1.1.0",
    "openai": "^4.67.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

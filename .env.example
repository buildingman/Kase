# === Kase 配置示例 ===
# 复制为 .env 后填入真实值：cp .env.example .env

# AI 供应商：kilo（推荐）/ openrouter / custom
KASE_PROVIDER=kilo

# AI API Key（统一入口，按当前 provider 使用）
# - kilo:       https://app.kilo.ai
# - openrouter: https://openrouter.ai/keys
KASE_API_KEY=

# 模型 ID（provider/model 格式，留空则用所选 provider 的默认值）
# 推荐 kilo: anthropic/claude-sonnet-4.5
# 推荐 openrouter: deepseek/deepseek-v4-flash
KASE_MODEL=

# 自定义网关 baseUrl（仅 KASE_PROVIDER=custom 时需要）
# KASE_BASE_URL=

# 目标 App bundleId（模拟器中安装后获取，例如 com.apple.Preferences）
KASE_APP_ID=

# iOS 模拟器 UDID（留空则用当前已启动的模拟器）
KASE_SIMULATOR_UDID=
